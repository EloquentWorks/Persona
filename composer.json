{
    "name": "eloquent-works/persona",
    "description": "Laravel Persona gives your users elegant public profiles with slugs, bios, avatars, links, visibility, and profile pages.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "profiles",
        "public-profiles",
        "persona",
        "eloquent-works"
    ],
    "authors": [
        {
            "name": "Eloquent Works"
        }
    ],
    "support": {
        "issues": "https://github.com/EloquentWorks/Persona/issues",
        "source": "https://github.com/EloquentWorks/Persona"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.15|^12.0|^13.0",
        "illuminate/database": "^11.15|^12.0|^13.0",
        "illuminate/routing": "^11.15|^12.0|^13.0",
        "illuminate/support": "^11.15|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "EloquentWorks\\Persona\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "tests/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "EloquentWorks\\Persona\\PersonaServiceProvider"
            ]
        }
    },
    "scripts": {
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse --memory-limit=1G",
        "test": "phpunit",
        "quality": [
            "@format:test",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
