{
    "name": "eloquent-works/persona",
    "description": "EloquentWorks Persona gives your users elegant public profiles with slugs, bios, avatars, links, visibility, and profile pages.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "profiles",
        "public-profiles",
        "persona",
        "eloquent-works"
    ],
    "authors": [
        {
            "name": "Eloquent Works"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.15|^12.0|^13.0",
        "illuminate/database": "^11.15|^12.0|^13.0",
        "illuminate/routing": "^11.15|^12.0|^13.0",
        "illuminate/support": "^11.15|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "EloquentWorks\\Persona\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "tests/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "EloquentWorks\\Persona\\PersonaServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
